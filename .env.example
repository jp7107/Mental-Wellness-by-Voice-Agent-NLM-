# ============================================
# MIND EASE — Environment Configuration
# ============================================
# Copy to .env and modify as needed.
# All values have sane defaults for local development.

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Model Paths (relative to project root) ---
WHISPER_MODEL_PATH=models/whisper-small-q4.bin
PHI3_MODEL_PATH=models/phi-3-mini-4k-q4.gguf
EMOTION_MODEL_PATH=models/qwen2.5-emotion-lora/adapter_model.onnx
KOKORO_MODEL_PATH=models/kokoro-v0.19/kokoro-v0_19.onnx
KOKORO_VOICES_PATH=models/kokoro-v0.19/voices

# --- Engine ---
ENGINE_BINARY_PATH=engine/build/mindease_engine
ENGINE_LOG_LEVEL=warn

# --- Pipeline Tuning ---
PIPELINE_CONFIG_PATH=config/pipeline.yaml
SAFETY_CONFIG_PATH=config/safety_responses.yaml

# --- Frontend ---
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/session
