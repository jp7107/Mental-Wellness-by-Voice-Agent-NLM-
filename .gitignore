# ============================================
# MIND EASE — Git Ignore Rules
# ============================================

# --- Environment ---
.env
.env.local

# --- Models (large binary files) ---
models/

# --- Build artifacts ---
engine/build/
engine/third_party/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
backend/.venv/

# --- Node.js ---
frontend/node_modules/
frontend/.next/
frontend/out/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Logs ---
*.log
logs/
